# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# Shell scripts
*.sh text eol=lf

# JSON files
*.json text eol=lf

# Markdown files
*.md text eol=lf

# Text files
*.txt text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Binary files
*.safetensors binary
*.bin binary
*.pt binary
*.pth binary
*.onnx binary
*.h5 binary
*.pkl binary
*.pickle binary
